{
  "expo": {
    "name": "Pawductivity",
    "slug": "pawductivity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon/logo-paw.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon/logo-paw.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C4C60"
    },
    "android": {
      "package": "com.production.pawductivity",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/logo-paw.png",
        "backgroundColor": "#0C4C60"
      },
      "blockedPermissions": ["com.google.android.gms.permission.AD_ID"],
      "predictiveBackGestureEnabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.production.pawductivity"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    }
  }
}
